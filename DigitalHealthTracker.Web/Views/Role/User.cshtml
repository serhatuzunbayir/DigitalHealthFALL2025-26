@model DigitalHealthTracker.Web.ViewModels.UserDashboardVm

<h1>User Dashboard</h1>

@if (TempData["UserMsg"] is not null)
{
    <p><b>@TempData["UserMsg"]</b></p>
}

@if (Model.Health is null)
{
    <p><i>Health summary not available.</i></p>
}
else
{
    <h3>Health Summary</h3>
    <table border="1" cellpadding="6" style="max-width:520px;">
        <tr><th>BMI</th><td>@Model.Health.Bmi</td></tr>
        <tr><th>Category</th><td>@Model.Health.Category</td></tr>
        <tr><th>Target Weight</th><td>@Model.Health.TargetWeightKg</td></tr>
        <tr><th>Weight Difference</th><td>@Model.Health.WeightDiffKg</td></tr>
    </table>
}

<hr />

<h3>Active Programs</h3>

@if (Model.ActiveAssignments.Count == 0)
{
    <p><i>No active programs.</i></p>
}
else
{
    <table border="1" cellpadding="6">
        <thead>
            <tr>
                <th>Program</th>
                <th>Trainer</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.ActiveAssignments)
            {
                <tr>
                    <td>@a.ProgramTitle</td>
                    <td>@a.TrainerName</td>
                    <td>
                        <form method="post" action="/User/Complete">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@a.Id" />
                            <button type="submit">Complete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />

<h3>Assigned Programs (All)</h3>

@if (Model.AssignedPrograms.Count == 0)
{
    <p><i>No assigned programs.</i></p>
}
else
{
    <table border="1" cellpadding="6">
        <thead>
            <tr>
                <th>Program</th>
                <th>Trainer</th>
                <th>Status</th>
                <th>AssignedAt</th>
                <th>ApprovedAt</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.AssignedPrograms)
            {
                <tr>
                    <td>@p.ProgramTitle</td>
                    <td>@p.TrainerName</td>
                    <td>@p.Status</td>
                    <td>@p.AssignedAt</td>
                    <td>@p.ApprovedAt</td>
                    <td>
                        @if (p.Status == "Pending")
                        {
                            <form method="post" action="/User/Approve">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit">Approve</button>
                            </form>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
