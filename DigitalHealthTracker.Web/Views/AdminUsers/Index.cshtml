@model List<DigitalHealthTracker.Web.ViewModels.Admin.AdminUserRowVm>

@{
    ViewData["Title"] = "Manage Users";
}

<h1>Manage Users</h1>

@if (Model == null || Model.Count == 0)
{
    <p>No users found.</p>
}
else
{
    <table border="1" cellpadding="6" cellspacing="0" style="width:100%;max-width:1100px;">
        <thead>
            <tr>
                <th style="width:70px;">Id</th>
                <th>Name</th>
                <th>Surname</th>
                <th style="width:170px;">Phone</th>
                <th>Email</th>
                <th style="width:90px;">H (cm)</th>
                <th style="width:90px;">W (kg)</th>
                <th style="width:90px;">Birth</th>
                <th style="width:220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.Id</td>
                    <td>@u.Name</td>
                    <td>@u.Surname</td>
                    <td>@u.Phone</td>
                    <td>@(string.IsNullOrWhiteSpace(u.Email) ? "-" : u.Email)</td>
                    <td>@(u.HeightCm?.ToString() ?? "-")</td>
                    <td>@(u.WeightKg?.ToString() ?? "-")</td>
                    <td>@(u.BirthYear?.ToString() ?? "-")</td>
                    <td style="display:flex; gap:8px; align-items:center;">
                        <a href="/Admin/Users/Edit/@u.Id">Edit</a>

                        <form method="post" action="/Admin/Users/Delete/@u.Id" style="margin:0;"
                              onsubmit="return confirm('Delete this user? This may also remove related logs/assignments.');">
                            @Html.AntiForgeryToken()
                            <button type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
