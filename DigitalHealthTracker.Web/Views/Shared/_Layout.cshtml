@{
    var displayName = Context.Session.GetString("DisplayName") ?? "";
    var role = Context.Session.GetString("Role") ?? "";
    var userId = Context.Session.GetInt32("UserId");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - DigitalHealthTracker</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header style="padding:10px;border-bottom:1px solid #ddd;display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;gap:10px;align-items:center;">
            <a href="/" style="text-decoration:none;font-weight:bold;">DigitalHealthTracker</a>

            @if (userId is not null)
            {
                @if (role == "Admin")
                {
                    <a href="/Admin">Admin</a>
                }
                else if (role == "Trainer")
                {
                    <a href="/Trainer">Trainer</a>
                    <a href="/Trainer/Programs">Programs</a>
                    <a href="/Trainer/Workouts">Workouts</a>
                    <a href="/Trainer/Assign">Assign</a>
                }
                else if (role == "User")
                {
                    <a href="/User">Dashboard</a>
                    <a href="/User/Profile">Profile</a>
                    <a href="/User/Logs">My Logs</a>
                }
            }
        </div>

        <div style="display:flex;gap:10px;align-items:center;">
            @if (userId is not null)
            {
                <span style="opacity:.8;">@displayName (@role)</span>
                <a href="/Account/Logout">Logout</a>
            }
            else
            {
                <a href="/Account/Login">Login</a>
            }
        </div>
    </header>

    <main style="max-width:1100px;margin:0 auto;padding:16px;">
        @if (TempData["Success"] is not null)
        {
            <div style="padding:10px;border:1px solid #8bc34a;background:#f1f8e9;margin-bottom:12px;">
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] is not null)
        {
            <div style="padding:10px;border:1px solid #f44336;background:#ffebee;margin-bottom:12px;">
                @TempData["Error"]
            </div>
        }

        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
