@model List<DigitalHealthTracker.Web.ViewModels.WorkoutLogRowVm>

<h1>User Logs</h1>
<p>UserId: @ViewBag.UserId</p>

@if (Model.Count == 0)
{
    <p>No logs.</p>
}
else
{
    <table border="1" cellpadding="6">
        <thead>
            <tr>
                <th>Program</th>
                <th>Workout</th>
                <th>Day</th>
                <th>Sets</th>
                <th>Reps</th>
                <th>Completed At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var x in Model)
            {
                <tr>
                    <td>@x.ProgramTitle</td>
                    <td>@x.WorkoutName</td>
                    <td>@x.DayNo</td>
                    <td>@x.Sets</td>
                    <td>@x.Reps</td>
                    <td>@x.CompletedAt</td>
                </tr>
            }
        </tbody>
    </table>
}
