@model DigitalHealthTracker.Web.ViewModels.UserDashboardVm

@{
    ViewData["Title"] = "Dashboard";
}

<h2>User Dashboard</h2>

<hr />

<h3>Health Summary</h3>

<table border="1" cellpadding="6" style="max-width:520px;">
    <tr><th>BMI</th><td>@Model.Health.Bmi</td></tr>
    <tr><th>Category</th><td>@Model.Health.Category</td></tr>
    <tr><th>Target Weight</th><td>@Model.Health.TargetWeight</td></tr>
    <tr><th>Weight Difference</th><td>@Model.Health.WeightDiff</td></tr>
</table>

<hr />

<h3>Active Programs</h3>

@if (Model.ActiveAssignments.Count == 0)
{
    <p><i>No active programs.</i></p>
}
else
{
    <table border="1" cellpadding="6">
        <thead>
            <tr>
                <th>Program</th>
                <th>Trainer</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.ActiveAssignments)
            {
                <tr>
                    <td>@a.ProgramTitle</td>
                    <td>@a.TrainerName</td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />

<h3>Assigned Programs (All)</h3>

@if (Model.AssignedPrograms.Count == 0)
{
    <p><i>No assigned programs.</i></p>
}
else
{
    <table border="1" cellpadding="6">
        <thead>
            <tr>
                <th>Program</th>
                <th>Trainer</th>
                <th>Status</th>
                <th>AssignedAt</th>
                <th>ApprovedAt</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.AssignedPrograms)
            {
                <tr>
                    <td>@p.ProgramTitle</td>
                    <td>@p.TrainerName</td>
                    <td>@p.Status</td>
                    <td>@p.AssignedAt</td>
                    <td>@p.ApprovedAt</td>
                </tr>
            }
        </tbody>
    </table>
}
