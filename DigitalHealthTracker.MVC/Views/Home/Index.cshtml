@using DigitalHealthTracker.Web.Models
@model List<UserViewModel>

@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="text-center mb-5">
    <h1 class="display-5 fw-bold text-primary">Digital Health Tracker</h1>
    <p class="lead text-muted">Sistemdeki kayıtlı kullanıcıların anlık durumu.</p>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3 shadow-sm">
            <div class="card-header">Toplam Kullanıcı</div>
            <div class="card-body">
                <h2 class="card-title">@Model.Count</h2>
                <p class="card-text">Sisteme kayıtlı aktif üye.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3 shadow-sm">
            <div class="card-header">Sistem Durumu</div>
            <div class="card-body">
                <h2 class="card-title">Aktif</h2>
                <p class="card-text">API bağlantısı başarılı.</p>
            </div>
        </div>
    </div>
</div>

<div class="card shadow">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 text-secondary">📋 Kullanıcı Listesi</h5>
    </div>
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#ID</th>
                    <th>Ad Soyad</th>
                    <th>İletişim</th>
                    <th>Doğum Yılı</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@user.user_id</span></td>

                            <td>
                                <div class="fw-bold">@user.user_name @user.user_surname</div>
                                <small class="text-muted">Kullanıcı</small>
                            </td>

                            <td>
                                <div><i class="bi bi-envelope"></i> @user.user_email</div>
                                <div class="small text-muted"><i class="bi bi-telephone"></i> @user.user_phone</div>
                            </td>

                            <td>@user.user_birthYear</td>

                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary">Detay</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-exclamation-circle fs-3 d-block mb-2"></i>
                            Veri bulunamadı veya API'ye ulaşılamıyor.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>