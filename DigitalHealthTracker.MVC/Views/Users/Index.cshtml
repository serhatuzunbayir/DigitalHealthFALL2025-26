@model List<DigitalHealthTracker.Web.Models.UserViewModel>

@{
    ViewData["Title"] = "Kullanıcı Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>👥 Kullanıcılar</h2>
        <a href="#" class="btn btn-success">
            <i class="bi bi-plus-lg"></i> Yeni Kullanıcı Ekle
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Ad Soyad</th>
                        <th>Email</th>
                        <th>Telefon</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">#@user.user_id</span></td>
                                <td class="fw-bold">@user.user_name @user.user_surname</td>
                                <td>
                                    <a href="mailto:@user.user_email" class="text-decoration-none">
                                        @user.user_email
                                    </a>
                                </td>
                                <td>@user.user_phone</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary">Düzenle</button>
                                    <button class="btn btn-sm btn-outline-danger">Sil</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                Henüz hiç kullanıcı kaydı yok veya API'ye ulaşılamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>